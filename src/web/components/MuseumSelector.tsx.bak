// ============================================================
// 파일: src/web/components/MuseumSelector.tsx
// 역할: 박물관 선택 온보딩 화면
// ============================================================

"use client";

import { useState, useEffect, useCallback, useRef } from "react";
import Image from "next/image";
import {
  MapPin,
  Search,
  Globe,
  Loader2,
  Star,
  ArrowLeft,
  Landmark,
  MapPinOff,
  X,
  ChevronDown,
} from "lucide-react";
import { cn } from "@web/lib/utils";
import { t, type Locale } from "@shared/i18n";
import type { MuseumContext } from "@shared/types/live-session";

interface MuseumInfo {
  id: string;
  name: string;
  address?: string;
  location: { lat: number; lng: number };
  distanceMeters?: number;
  distance?: number;
  photoUrl?: string;
  rating?: number;
  openNow?: boolean;
  isOpen?: boolean;
  type?: string;
}

interface MuseumSelectorProps {
  userLocation: { lat: number; lng: number } | null;
  isLoadingLocation?: boolean;
  locationDenied?: boolean;
  onSelect: (museum: MuseumContext) => void;
  onSkip: () => void;
  onBack?: () => void;
  locale?: Locale;
}

function formatDistance(meters: number): string {
  if (meters < 1000) return `${Math.round(meters)}m`;
  return `${(meters / 1000).toFixed(1)}km`;
}

// ── Shimmer 스켈레톤 ──────────────────────────────────────────
function MuseumCardSkeleton({ index = 0 }: { index?: number }) {
  return (
    <div
      className="relative rounded-xl bg-white/[0.04] border border-white/[0.06] overflow-hidden"
      style={{ animation: `cardReveal 0.35s ease-out both`, animationDelay: `${index * 55}ms` }}
    >
      <div
        className="absolute inset-0 z-10 animate-shimmer"
        style={{
          background:
            "linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.07) 50%, transparent 100%)",
        }}
      />
      <div className="w-full h-[104px] bg-white/[0.07]" />
      <div className="p-2.5 flex flex-col gap-2">
        <div className="h-3 bg-white/[0.09] rounded-full w-4/5" />
        <div className="h-2.5 bg-white/[0.06] rounded-full w-2/5" />
      </div>
    </div>
  );
}

// ── 2열 카드 ──────────────────────────────────────────────────
function MuseumCard({
  museum,
  onClick,
  locale = "ko",
  index = 0,
}: {
  museum: MuseumInfo;
  onClick: () => void;
  locale?: Locale;
  index?: number;
}) {
  const dist = museum.distanceMeters ?? museum.distance ?? 0;
  const isOpen = museum.openNow ?? museum.isOpen;

  return (
    <button
      onClick={onClick}
      className="w-full text-left bg-white/[0.04] hover:bg-white/[0.08] rounded-xl
                 border border-white/[0.08] hover:border-white/[0.16]
                 transition-colors duration-200 active:scale-[0.97] overflow-hidden"
      style={{
        boxShadow:
          "0 2px 12px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.05)",
        animation: `cardReveal 0.4s ease-out both`,
        animationDelay: `${index * 65}ms`,
      }}
    >
      <div className="relative w-full h-[104px] bg-white/[0.06]">
        {museum.photoUrl ? (
          <Image
            src={museum.photoUrl}
            alt={museum.name}
            fill
            className="object-cover"
            unoptimized
          />
        ) : (
          <div className="w-full h-full flex items-center justify-center">
            <Landmark className="w-8 h-8 text-gray-600" />
          </div>
        )}
        {isOpen !== undefined && (
          <span
            className={cn(
              "absolute top-2 right-2 text-[10px] font-semibold px-2 py-0.5 rounded-full shadow-sm",
              isOpen
                ? "bg-emerald-500 text-white"
                : "bg-red-500 text-white",
            )}
          >
            {isOpen ? t("museum.open", locale) : t("museum.closed", locale)}
          </span>
        )}
      </div>

      {/* 텍스트 영역 — 고정 높이, 단일 라인 truncate */}
      <div className="px-2.5 pt-2 pb-2.5 h-[52px] flex flex-col justify-between overflow-hidden">
        <h3 className="text-xs font-semibold text-white truncate">
          {museum.name}
        </h3>
        <div className="flex items-center gap-2">
          {dist > 0 && (
            <span className="text-[10px] text-gray-500 shrink-0">
              {formatDistance(dist)}
            </span>
          )}
          {museum.rating && (
            <span className="flex items-center gap-0.5 text-[10px] text-amber-400 shrink-0">
              <Star className="w-2.5 h-2.5 fill-amber-400" />
              {museum.rating.toFixed(1)}
            </span>
          )}
        </div>
      </div>
    </button>
  );
}

// ── 확인 모달 (바텀시트) ─────────────────────────────────────
function MuseumConfirmModal({
  museum,
  onConfirm,
  onClose,
  locale = "ko",
}: {
  museum: MuseumInfo;
  onConfirm: () => void;
  onClose: () => void;
  locale?: Locale;
}) {
  const dist = museum.distanceMeters ?? museum.distance ?? 0;
  const isOpen = museum.openNow ?? museum.isOpen;

  return (
    <div
      className="fixed inset-0 z-50 flex items-end justify-center"
      onClick={onClose}
    >
      <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" />
      <div
        className="relative w-full max-w-sm rounded-t-3xl overflow-hidden"
        style={{
          background: "rgba(18, 14, 9, 0.97)",
          border: "1px solid rgba(255,255,255,0.08)",
          borderBottom: "none",
          boxShadow: "0 -20px 60px rgba(0,0,0,0.6)",
          animation: "slide-up 0.3s cubic-bezier(0.16, 1, 0.3, 1)",
        }}
        onClick={(e) => e.stopPropagation()}
      >
        <div className="flex justify-center pt-3 pb-1">
          <div className="w-10 h-1 rounded-full bg-white/20" />
        </div>
        <button
          onClick={onClose}
          className="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/[0.06] flex items-center justify-center hover:bg-white/10 transition-colors"
        >
          <X className="w-4 h-4 text-gray-400" />
        </button>

        {museum.photoUrl && (
          <div className="relative mx-4 mt-2 h-44 rounded-2xl overflow-hidden">
            <Image
              src={museum.photoUrl}
              alt={museum.name}
              fill
              className="object-cover"
              unoptimized
            />
            <div
              className="absolute inset-0"
              style={{
                background:
                  "linear-gradient(to top, rgba(18,14,9,0.5) 0%, transparent 50%)",
              }}
            />
          </div>
        )}

        <div className="px-5 pt-4 pb-2">
          <h2 className="text-lg font-bold text-white leading-snug">
            {museum.name}
          </h2>
          <div className="flex items-center gap-3 mt-2 flex-wrap">
            {dist > 0 && (
              <span className="flex items-center gap-1 text-xs text-gray-400">
                <MapPin className="w-3 h-3 text-timelens-gold" />
                {formatDistance(dist)}
              </span>
            )}
            {museum.rating && (
              <span className="flex items-center gap-1 text-xs text-amber-400">
                <Star className="w-3 h-3 fill-amber-400" />
                {museum.rating.toFixed(1)}
              </span>
            )}
            {isOpen !== undefined && (
              <span
                className={cn(
                  "text-xs font-semibold px-2 py-0.5 rounded-full",
                  isOpen
                    ? "bg-emerald-500 text-white"
                    : "bg-red-500 text-white",
                )}
              >
                {isOpen ? t("museum.open", locale) : t("museum.closed", locale)}
              </span>
            )}
          </div>
          {museum.address && (
            <p className="text-[11px] text-gray-500 mt-2 leading-relaxed">
              {museum.address}
            </p>
          )}
        </div>

        <div className="flex gap-3 px-5 pt-3 pb-6">
          <button
            onClick={onClose}
            className="flex-1 py-3.5 rounded-2xl text-sm font-medium text-gray-400 bg-white/[0.06] hover:bg-white/[0.10] border border-white/[0.08] transition-colors"
          >
            {t("museum.confirmCancel", locale)}
          </button>
          <button
            onClick={onConfirm}
            className="flex-[2] py-3.5 rounded-2xl text-sm font-semibold text-black bg-gradient-to-r from-timelens-gold to-timelens-bronze hover:brightness-110 active:scale-[0.98] transition-all shadow-lg shadow-timelens-gold/20"
          >
            {t("museum.confirmStart", locale)}
          </button>
        </div>
      </div>
    </div>
  );
}

// ── 메인 컴포넌트 ─────────────────────────────────────────────
export default function MuseumSelector({
  userLocation,
  isLoadingLocation = false,
  locationDenied = false,
  onSelect,
  onSkip,
  onBack,
  locale = "ko",
}: MuseumSelectorProps) {
  const [nearbyMuseums, setNearbyMuseums] = useState<MuseumInfo[]>([]);
  const [searchResults, setSearchResults] = useState<MuseumInfo[]>([]);
  const [searchQuery, setSearchQuery] = useState("");
  const [nearbyFetched, setNearbyFetched] = useState(false);
  const [isLoadingNearby, setIsLoadingNearby] = useState(false);
  const [isSearching, setIsSearching] = useState(false);
  const [nearbyError, setNearbyError] = useState(false);
  const [mounted, setMounted] = useState(false);
  const [selectedMuseum, setSelectedMuseum] = useState<MuseumInfo | null>(null);
  const [isAtBottom, setIsAtBottom] = useState(false);
  const scrollRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    setMounted(true);
  }, []);

  const checkScrollBottom = useCallback(() => {
    const el = scrollRef.current;
    if (!el) return;
    const remaining = el.scrollHeight - el.scrollTop - el.clientHeight;
    setIsAtBottom(remaining < 32);
  }, []);

  useEffect(() => {
    const el = scrollRef.current;
    if (!el) return;
    el.addEventListener('scroll', checkScrollBottom, { passive: true });
    return () => el.removeEventListener('scroll', checkScrollBottom);
  }, [checkScrollBottom]);

  // 콘텐츠가 바뀔 때(카드 로드/검색 결과) 다음 프레임에 재체크
  useEffect(() => {
    requestAnimationFrame(checkScrollBottom);
  }, [nearbyMuseums, searchResults, nearbyFetched, checkScrollBottom]);

  useEffect(() => {
    if (!userLocation) return;
    const controller = new AbortController();
    setIsLoadingNearby(true);
    setNearbyError(false);

    fetch(
      `/api/museums/nearby?lat=${userLocation.lat}&lng=${userLocation.lng}&radius=2000`,
      {
        signal: controller.signal,
      },
    )
      .then((res) => res.json())
      .then((data) => {
        if (data.success) setNearbyMuseums(data.data?.museums ?? []);
        else setNearbyError(true);
        setIsLoadingNearby(false);
        setNearbyFetched(true);
      })
      .catch((err) => {
        if (err instanceof DOMException && err.name === "AbortError") return;
        setNearbyError(true);
        setIsLoadingNearby(false);
        setNearbyFetched(true);
      });

    return () => controller.abort();
  }, [userLocation]);

  const handleSearch = useCallback(async () => {
    if (searchQuery.trim().length < 2) return;
    setIsSearching(true);
    try {
      const res = await fetch(
        `/api/museums/search?q=${encodeURIComponent(searchQuery.trim())}&lang=${locale}`,
      );
      const data = await res.json();
      if (data.success) setSearchResults(data.data?.museums ?? []);
    } catch {
      // ignore
    } finally {
      setIsSearching(false);
    }
  }, [searchQuery, locale]);

  const confirmSelect = useCallback(
    (museum: MuseumInfo) => {
      onSelect({
        name: museum.name,
        placeId: museum.id,
        address: museum.address ?? "",
        location: museum.location,
        photoUrl: museum.photoUrl,
        rating: museum.rating,
        openNow: museum.openNow ?? museum.isOpen,
      });
      setSelectedMuseum(null);
    },
    [onSelect],
  );

  // 스켈레톤: 위치 로딩 중이거나 위치 있지만 API 페칭 전
  const showNearbySkeletons =
    !nearbyFetched &&
    !nearbyError &&
    !locationDenied &&
    (isLoadingLocation || !!userLocation);

  return (
    <div
      ref={scrollRef}
      className="fixed inset-0 bg-canvas overflow-y-auto scrollbar-hide"
      style={{ WebkitOverflowScrolling: "touch", overscrollBehaviorY: "none" } as React.CSSProperties}
    >
      {/* 배경 오브 — fixed로 스크롤에 무관하게 고정 */}
      <div
        className="fixed top-0 left-1/2 -translate-x-1/2 w-[400px] h-[400px] rounded-full opacity-15 blur-[120px] pointer-events-none z-0"
        style={{
          background: "radial-gradient(circle, #D4A574 0%, transparent 70%)",
        }}
      />

      {/* ── 1. 헤더 + 검색창 (sticky) ── */}
      <div
        className="sticky top-0 z-20 w-full"
        style={{
          background:
            "linear-gradient(to bottom, rgba(15,11,7,0.97) 80%, transparent 100%)",
          backdropFilter: "blur(12px)",
          WebkitBackdropFilter: "blur(12px)",
        }}
      >
        <div
          className={cn(
            "relative w-full max-w-sm mx-auto px-6 pt-safe-top pb-4",
            "transition-all duration-350 ease-out",
            mounted ? "opacity-100 translate-y-0" : "opacity-0 translate-y-4",
          )}
          style={{ paddingTop: `calc(env(safe-area-inset-top) + 5.5rem)` }}
        >
          {onBack && (
            <button
              onClick={onBack}
              className="absolute left-4 w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.06] flex items-center justify-center hover:bg-white/10 transition-colors"
              style={{ top: `calc(env(safe-area-inset-top) + 1rem)` }}
            >
              <ArrowLeft className="w-4.5 h-4.5 text-gray-400" />
            </button>
          )}
          <button
            onClick={onSkip}
            className="absolute right-4 flex items-center gap-1.5 px-3 py-2 rounded-full text-xs text-gray-400 hover:text-gray-200 bg-white/[0.05] hover:bg-white/[0.09] border border-white/[0.07] transition-all duration-200"
            style={{ top: `calc(env(safe-area-inset-top) + 1rem)` }}
          >
            <Globe className="w-3.5 h-3.5" />
            <span>{t("museum.skip", locale)}</span>
          </button>

          <div
            className="text-center animate-char-in"
            style={{ animationDuration: "0.6s" }}
          >
            <h1
              style={{
                fontFamily: "var(--font-display)",
                fontSize: "clamp(2.2rem, 9vw, 2.9rem)",
                fontWeight: 700,
                letterSpacing: "-0.02em",
                lineHeight: 1,
                color: "#D4A574",
                textShadow: "0 0 40px rgba(212,165,116,0.25)",
              }}
            >
              TimeLens
            </h1>
            <div className="flex items-center justify-center gap-3 mt-3.5">
              <div
                className="h-px w-12 animate-line-in"
                style={{
                  background:
                    "linear-gradient(to right, transparent, rgba(212,165,116,0.4))",
                }}
              />
              <div className="animate-line-in w-1 h-1 rounded-full bg-timelens-gold/50" />
              <div
                className="h-px w-12 animate-line-in"
                style={{
                  background:
                    "linear-gradient(to left, transparent, rgba(212,165,116,0.4))",
                }}
              />
            </div>
            <p
              className="animate-subtitle-in mt-2.5 text-xs tracking-[0.18em] uppercase"
              style={{ color: "rgba(180,145,100,0.65)" }}
            >
              {t("museum.title", locale)}
            </p>
          </div>

          <div className="mt-3 flex gap-2">
            <input
              type="text"
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              onKeyDown={(e) => e.key === "Enter" && handleSearch()}
              placeholder={t("museum.searchPlaceholder", locale)}
              className="flex-1 px-4 py-3 bg-white/10 rounded-xl text-white text-sm placeholder:text-gray-500 outline-none focus:ring-2 focus:ring-timelens-gold/40 border border-white/10"
            />
            <button
              onClick={handleSearch}
              disabled={isSearching || searchQuery.trim().length < 2}
              className="px-4 py-3 bg-white/10 hover:bg-white/15 rounded-xl border border-white/10 transition-colors disabled:opacity-40"
            >
              {isSearching ? (
                <Loader2 className="w-5 h-5 text-gray-300 animate-spin" />
              ) : (
                <Search className="w-5 h-5 text-gray-300" />
              )}
            </button>
          </div>
        </div>
      </div>

      {/* ── 2. 섹션 라벨 ── */}
      {!searchResults.length && (
        <div className="relative z-10 w-full max-w-sm mx-auto px-6 pb-2 pt-1">
          <div className="flex items-center gap-1.5">
            {locationDenied ? (
              <MapPinOff className="w-3.5 h-3.5 text-gray-500" />
            ) : (
              <MapPin className="w-3.5 h-3.5 text-timelens-gold" />
            )}
            <span
              className={cn(
                "text-xs",
                locationDenied ? "text-gray-500" : "text-gray-400",
              )}
            >
              {locationDenied
                ? t("museum.locationDenied", locale)
                : isLoadingLocation
                  ? t("museum.locationLoading", locale)
                  : t("museum.nearbyLabel", locale)}
            </span>
          </div>
        </div>
      )}

      {/* ── 3. 박물관 리스트 ── */}
      <div
        className="relative z-10 w-full max-w-sm mx-auto px-6 pb-safe-bottom"
        style={{ paddingBottom: `calc(env(safe-area-inset-bottom) + 2rem)` }}
      >
        {!searchResults.length && (
          <div>
            {/* 위치 거부 fallback */}
            {locationDenied && (
              <div className="flex flex-col items-center gap-3 py-10 px-4 text-center">
                <MapPinOff className="w-9 h-9 text-gray-700" />
                <p className="text-xs text-gray-500 leading-relaxed">
                  {t("museum.locationDeniedNote", locale)}
                </p>
              </div>
            )}
            {showNearbySkeletons && (
              <div className="grid grid-cols-2 gap-2">
                {[0, 1, 2, 3].map((i) => (
                  <MuseumCardSkeleton key={i} index={i} />
                ))}
              </div>
            )}
            {nearbyError && !isLoadingNearby && (
              <p className="text-xs text-gray-500 text-center py-6">
                {t("museum.nearbyEmpty", locale)}
              </p>
            )}
            {nearbyFetched && nearbyMuseums.length > 0 && (
              <div key="nearby-loaded" className="grid grid-cols-2 gap-2">
                {nearbyMuseums.map((museum, i) => (
                  <MuseumCard
                    key={museum.id}
                    museum={museum}
                    onClick={() => setSelectedMuseum(museum)}
                    locale={locale}
                    index={i}
                  />
                ))}
              </div>
            )}
          </div>
        )}

        {(searchResults.length > 0 || isSearching) && (
          <div>
            <div className="py-2 mb-3">
              <div className="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/[0.07] border border-white/[0.10]">
                <Search className="w-3.5 h-3.5 text-timelens-gold" />
                <span className="text-xs text-gray-300 font-medium">
                  {t("museum.searchResults", locale)}
                </span>
              </div>
            </div>
            {isSearching && (
              <div className="grid grid-cols-2 gap-2">
                {[0, 1, 2, 3].map((i) => (
                  <MuseumCardSkeleton key={i} index={i} />
                ))}
              </div>
            )}
            {!isSearching && (
              <div key="search-loaded" className="grid grid-cols-2 gap-2">
                {searchResults.map((museum, i) => (
                  <MuseumCard
                    key={museum.id}
                    museum={museum}
                    onClick={() => setSelectedMuseum(museum)}
                    locale={locale}
                    index={i}
                  />
                ))}
              </div>
            )}
          </div>
        )}
      </div>

      {/* ── 하단 스크롤 힌트 오버레이 ── */}
      <div
        className="fixed bottom-0 left-0 right-0 z-30 pointer-events-none transition-opacity duration-500"
        style={{ opacity: isAtBottom ? 0 : 1 }}
      >
        {/* blur + gradient 레이어 */}
        <div
          className="h-28"
          style={{
            background: 'linear-gradient(to top, rgba(15,11,7,0.96) 0%, rgba(15,11,7,0.5) 50%, transparent 100%)',
            backdropFilter: 'blur(1px)',
            WebkitBackdropFilter: 'blur(1px)',
            maskImage: 'linear-gradient(to top, black 40%, transparent 100%)',
            WebkitMaskImage: 'linear-gradient(to top, black 40%, transparent 100%)',
          }}
        />
        {/* 아래 화살표 */}
        <div
          className="absolute bottom-4 left-1/2 -translate-x-1/2"
          style={{ paddingBottom: 'env(safe-area-inset-bottom)' }}
        >
          <ChevronDown
            className="w-5 h-5 text-timelens-gold/60 animate-bounce"
            style={{ animationDuration: '1.4s' }}
          />
        </div>
      </div>

      {/* ── 확인 모달 ── */}
      {selectedMuseum && (
        <MuseumConfirmModal
          museum={selectedMuseum}
          onConfirm={() => confirmSelect(selectedMuseum)}
          onClose={() => setSelectedMuseum(null)}
          locale={locale}
        />
      )}
    </div>
  );
}
